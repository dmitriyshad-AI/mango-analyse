DATABASE_URL=sqlite:///mango_mvp.db

# Recommended baseline for this project: MLX + GigaAM + Codex CLI merge/analyze
# Providers: openai, mlx, gigaam or mock
TRANSCRIBE_PROVIDER=mlx
DUAL_TRANSCRIBE_ENABLED=true
# optional second pass provider: gigaam|mlx|openai|mock
SECONDARY_TRANSCRIBE_PROVIDER=gigaam
# how to build final text from A/B variants: primary|rule|openai|ollama|codex_cli
DUAL_MERGE_PROVIDER=codex_cli
OPENAI_MERGE_MODEL=gpt-4o-mini
CODEX_MERGE_MODEL=gpt-5.4
CODEX_CLI_COMMAND=codex
CODEX_CLI_TIMEOUT_SEC=120
# if A and B are too similar, keep A without LLM merge
DUAL_MERGE_SIMILARITY_THRESHOLD=0.985
ANALYZE_PROVIDER=codex_cli
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-mlx
# Recommended false for long phone calls to reduce repetition loops
MLX_CONDITION_ON_PREVIOUS_TEXT=false
# Recommended true for better turn timing/order from word-level timestamps
MLX_WORD_TIMESTAMPS=true
GIGAAM_MODEL=v2_rnnt
GIGAAM_DEVICE=cpu
GIGAAM_SEGMENT_SEC=20
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
ANALYZE_OLLAMA_NUM_PREDICT=500
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_THINK=medium
OLLAMA_TEMPERATURE=0
TRANSCRIBE_LANGUAGE=ru
TRANSCRIPT_EXPORT_DIR=transcripts
SPLIT_STEREO_CHANNELS=true
STEREO_OVERLAP_SIMILARITY_THRESHOLD=0.97
STEREO_OVERLAP_MIN_CHARS=80
# role assignment for mono/fallback calls: off|rule|openai_selective|ollama_selective
MONO_ROLE_ASSIGNMENT_MODE=rule
MONO_ROLE_ASSIGNMENT_MIN_CONFIDENCE=0.62
MONO_ROLE_ASSIGNMENT_LLM_THRESHOLD=0.72
OPENAI_ROLE_ASSIGN_MODEL=gpt-4o-mini
TRANSCRIBE_MAX_ATTEMPTS=3
RESOLVE_MAX_ATTEMPTS=2
ANALYZE_MAX_ATTEMPTS=3
SYNC_MAX_ATTEMPTS=3
RESOLVE_MIN_DURATION_SEC=30
RESOLVE_LLM_TRIGGER_SCORE=75
RESOLVE_ACCEPT_SCORE=75
# resolver for risky calls: ollama|openai|codex_cli|off
RESOLVE_LLM_PROVIDER=codex_cli
# run LLM resolve not only by low score, but also for risky turn-order calls
RESOLVE_LLM_FOR_RISKY=true
# optional rescue ASR provider (auto if empty): mlx|gigaam|openai|mock
RESOLVE_RESCUE_PROVIDER=
RESOLVE_RESCUE_DUAL_ENABLED=false
# post-filter adjacent cross-speaker lines with identical timestamps
RESOLVE_POSTFILTER_SAME_TS=true
# if same-ts cross-speaker events >= threshold, run rescue even when score is acceptable
RESOLVE_RISKY_SAME_TS_THRESHOLD=2
RESOLVE_AGGRESSIVE_RESCUE_FOR_RISKY=true
RETRY_BASE_DELAY_SEC=30
WORKER_POLL_SEC=10
WORKER_MAX_IDLE_CYCLES=30

# amoCRM integration
AMOCRM_BASE_URL=https://example.amocrm.ru
AMOCRM_ACCESS_TOKEN=
AMOCRM_REFRESH_TOKEN=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
AMOCRM_TOKEN_CACHE_PATH=.amocrm_tokens.json

# Optional: custom fields in contact card
AMOCRM_INTERESTS_FIELD_ID=
AMOCRM_STUDENT_GRADE_FIELD_ID=
AMOCRM_TARGET_PRODUCT_FIELD_ID=
AMOCRM_PERSONAL_OFFER_FIELD_ID=
AMOCRM_BUDGET_FIELD_ID=
AMOCRM_TIMELINE_FIELD_ID=
AMOCRM_NEXT_STEP_FIELD_ID=
AMOCRM_FOLLOWUP_SCORE_FIELD_ID=

# Optional: auto task in amoCRM when score >= threshold
AMOCRM_TASK_TYPE_ID=
AMOCRM_TASK_RESPONSIBLE_USER_ID=
FOLLOW_UP_TASK_THRESHOLD=70

# Keep true for safe dry-run first launch
SYNC_DRY_RUN=true
